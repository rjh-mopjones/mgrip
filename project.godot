; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Margin's Grip"
config/description="A 3D voxel open-world survival RPG on a tidally locked planet."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
GenerationManager="*res://scripts/autoload/generation_manager.gd"
Flythrough="*res://scripts/autoload/flythrough.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray()

