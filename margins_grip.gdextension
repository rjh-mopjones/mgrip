[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
macos.debug = "res://gdextension/target/release/libmargins_grip.dylib"
macos.release = "res://gdextension/target/release/libmargins_grip.dylib"
linux.debug.x86_64 = "res://gdextension/target/debug/libmargins_grip.so"
linux.release.x86_64 = "res://gdextension/target/release/libmargins_grip.so"
windows.debug.x86_64 = "res://gdextension/target/debug/margins_grip.dll"
windows.release.x86_64 = "res://gdextension/target/release/margins_grip.dll"
